{
  "name": "all-ent-app",
  "version": "1.0.0",
  "description": "All Entertainment App wrapper",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "test": "echo \"Error: no test specified\" && exit 1",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "build:win": "electron-builder --win nsis --x64"
  },
  "build": {
    "appId": "com.alinsamba.all-ent-app",
    "productName": "All Ent App",
    "copyright": "Copyright © 2026 Nsamba Ali",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "aea.png",
      "aea.ico",
      "package.json"
    ],
    "electronFuses": {
      "runAsNode": false,
      "enableCookieEncryption": false,
      "enableNodeOptionsEnvironmentVariable": false,
      "enableNodeCliInspectArguments": false,
      "enableEmbeddedAsarIntegrityValidation": false,
      "onlyLoadAppFromAsar": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "aea.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "aea.ico",
      "uninstallerIcon": "aea.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "All Ent App"
    }
  },
  "keywords": [],
  "author": "Nsamba Ali <alinsamba@outlook.com>",
  "license": "ISC",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron/fuses": "^1.8.0",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "@ghostery/adblocker-electron": "^2.18.1",
    "adm-zip": "^0.6.0",
    "cross-fetch": "^4.1.0",
    "electron-squirrel-startup": "^1.0.1"
  }
}
